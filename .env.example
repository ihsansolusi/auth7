# .env.example — copy ke .env dan isi nilai yang sesuai
# File .env tidak boleh di-commit ke git
#
# PRASYARAT: Core7 Unified Infra harus running.
#   cd <core7-devroot> && docker compose -f docker-compose.infra.yml up -d

# Database
DATABASE_URL=postgres://auth7:auth7secret@localhost:5432/auth7?sslmode=disable
DATABASE_REPLICA_URL=

# Redis
REDIS_URL=redis://localhost:6379/0

# Token
JWT_SECRET=your-32-byte-secret-here-replace-this-now

# NATS (optional)
NATS_URL=nats://localhost:4222

# OTEL (optional)
OTEL_ENABLED=true
OTEL_ENDPOINT=localhost:4317

# Diagnostics (optional)
DIAGNOSTIC_SECRET=
